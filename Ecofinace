function Donut(props) {
var segs = props.segs;
var size = 120;
var tot = 0;
for (var i = 0; i < segs.length; i++) tot += segs[i].value;
var cum = 0;
var r = (size - 16) / 2;
var cx = size / 2;
var cy = size / 2;
var paths = [];
for (var j = 0; j < segs.length; j++) {
var sa = (cum / tot) * 2 * Math.PI - Math.PI / 2;
cum += segs[j].value;
var ea = (cum / tot) * 2 * Math.PI - Math.PI / 2;
var la = segs[j].value / tot > 0.5 ? 1 : 0;
paths.push(<path key={j} d={“M “ + (cx + r * Math.cos(sa)) + “ “ + (cy + r * Math.sin(sa)) + “ A “ + r + “ “ + r + “ 0 “ + la + “ 1 “ + (cx + r * Math.cos(ea)) + “ “ + (cy + r * Math.sin(ea))} fill=“none” stroke={segs[j].color} strokeWidth={14} strokeLinecap=“round” />);
}
return (
<svg width={size} height={size}>
<circle cx={cx} cy={cy} r={r} fill="none" stroke="rgba(255,255,255,0.06)" strokeWidth={14} />
{paths}
<text x={cx} y={cy - 6} textAnchor=“middle” fill=”#fff” fontSize=“16” fontWeight=“700”>{tot.toFixed(0)}€</text>
<text x={cx} y={cy + 10} textAnchor=“middle” fill=”#888” fontSize=“9”>TOTAL</text>
</svg>
);
}

